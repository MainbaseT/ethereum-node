{
  "name": "stereum-launcher",
  "version": "2.4.10",
  "private": true,
  "description": "Stereum Ethereum Node Setup Launcher",
  "author": {
    "name": "Stereum Launcher Team",
    "email": "office@stereum.com",
    "url": "https://stereum.com/"
  },
  "scripts": {
    "serve": "vue-cli-service serve --port 8081",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "build-themes": "node-sass src/styles/themes -o public/themes",
    "electron:build": "vue-cli-service electron:build --publish never",
    "electron:serve": "vue-cli-service electron:serve",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps",
    "test:unit": "jest '(\\.test|\\.spec)\\.js' --coverage",
    "test:int": "jest '\\.int\\.js'",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:other": "jest --silent --testPathPattern 'tests/(?!.*Service).*\\.int\\.js$'",
    "test:beacon": "jest --silent --testPathPattern 'tests/(?=.*BeaconService).*\\.int\\.js$'",
    "test:service": "jest --silent --testPathPattern 'tests/(?=.*Service)(?!.*Beacon).*\\.int\\.js$'",
    "test:cleanup": "node src/backend/tests/integration/Cleanup.js",
    "watch:css": "npx tailwindcss -i ./src/main.css -o ./public/output.css --watch",
    "lint:fix": "eslint src --fix",
    "stereum": "concurrently \"npm:electron:serve\" \"npm:watch:css\"",
    "backend:watch": "nodemon --watch 'src/backend' --exec 'npm run electron:serve'",
    "format": "prettier .  --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@sapien99/vue-cli-plugin-electron-builder-notarize": "^1.1.3",
    "@vue-hero-icons/outline": "^1.7.2",
    "@vue-hero-icons/solid": "^1.7.2",
    "@xterm/addon-attach": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "animate.css": "^4.1.1",
    "axios": "^1.15.2",
    "electron-builder": "^26.8.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "evilscan": "^1.9.1",
    "file-saver": "^2.0.5",
    "geoip-lite": "^2.0.1",
    "gsap": "^3.15.0",
    "jszip": "^3.10.1",
    "ping": "^1.0.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "semver": "^7.7.4",
    "ssh2": "^1.17.0",
    "swiper": "^12.1.3",
    "tailwindcss-animated": "^2.0.0",
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0",
    "vue-router": "^5.0.6",
    "vue3-apexcharts": "^1.11.1",
    "vue3-carousel": "^0.17.0",
    "vue3-circle-progress": "^1.0.7",
    "vuedraggable": "^2.24.3",
    "web3": "^4.16.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/runtime": "^7.29.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@vue/cli-service": "^5.0.9",
    "@vue/compiler-sfc": "^3.5.33",
    "@vueuse/core": "^14.2.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.17",
    "vue-cli-plugin-electron-builder": "^3.0.0-alpha.4",
    "vue-loader": "^17.4.2",
    "web3": "^4.16.0"
  },
  "license": "https://wrapbootstrap.com/help/licenses",
  "overrides": {
    "vue-cli-plugin-electron-builder": {
      "electron-builder": "^26.8.1"
    },
    "serialize-javascript": ">=7.0.5",
    "uuid": ">=14.0.0",
    "webpack-dev-server": ">=5.2.1"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:stereum-dev/ethereum-node.git"
  }
}
